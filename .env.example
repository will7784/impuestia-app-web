# ============================================
# ImpuestIA - Variables de Entorno
# Copia este archivo como .env y llena los valores
# NUNCA subas .env a git (ya está en .gitignore)
# ============================================

# --- DeepSeek Pro (Cerebro de ClaudIA) ---
# Obtén tu API key en: https://platform.deepseek.com/
VITE_DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
VITE_DEEPSEEK_MODEL=deepseek-chat

# --- Airtable (Base de datos de Leads y Ebooks) ---
# Crea una base en airtable.com y obtén tus credenciales
VITE_AIRTABLE_API_KEY=patxxxxxxxxxxxxxxxx
VITE_AIRTABLE_BASE_ID=appxxxxxxxxxxxxxxxx
VITE_AIRTABLE_LEADS_TABLE=Leads
VITE_AIRTABLE_EBOOKS_TABLE=Ebooks

# --- Email (Notificaciones por paso del embudo) ---
# Recomendado: Resend.com o SendGrid
VITE_SMTP_HOST=smtp.gmail.com
VITE_SMTP_PORT=587
VITE_SMTP_USER=claudia@impuestia.cl
VITE_SMTP_PASS=tu-app-password
VITE_NOTIFICATION_EMAIL=tu-email@ejemplo.cl

# --- WebPay / Transbank (Pagos) ---
# Regístrate en transbank.cl para obtener credenciales
VITE_WEBPAY_COMMERCE_CODE=5970xxxxxxxxxx
VITE_WEBPAY_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Google Drive (Testimonios + Herramientas) ---
# ID de la carpeta de Google Drive
VITE_GOOGLE_DRIVE_FOLDER_ID=1ABCxxxxxxxxxxxxxxxxxxx

# --- LinkedIn API (Automatización de posts) ---
# Crea una app en linkedin.com/developers
VITE_LINKEDIN_CLIENT_ID=78xxxxxxxxxx
VITE_LINKEDIN_CLIENT_SECRET=xxxxxxxx
VITE_LINKEDIN_REDIRECT_URI=https://tusitio.com/admin/linkedin/callback

# --- Admin Auth ---
# Contraseña para panel admin (cambia esto en producción)
VITE_ADMIN_PASSWORD=admin123
